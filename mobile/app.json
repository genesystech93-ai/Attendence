{
  "expo": {
    "name": "Genesoft Attendance",
    "slug": "genesoft-attendance",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.genesoftinfotech.attendance",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Genesoft Attendance requires access to your location to verify you are within the designated office geofence before you can clock in.",
        "NSFaceIDUsageDescription": "Genesoft Attendance requires Face ID to securely verify your identity and prevent buddy punching."
      }
    },
    "android": {
      "package": "com.genesoftinfotech.attendance",
      "versionCode": 1,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "USE_BIOMETRIC"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#F5820D",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-location",
      "expo-local-authentication"
    ]
  }
}
